    "summary": "Generate full-stack Angular + Firestore business applications from sample JSON data",
    "documentation": "https://github.com/your-repo/mcp-j2code-angular-firestore/blob/main/README.md",
    "repository": "https://github.com/your-repo/mcp-j2code-angular-firestore",
    "bugs": "https://github.com/your-repo/mcp-j2code-angular-firestore/issues",
    "ratings": 4.5,
